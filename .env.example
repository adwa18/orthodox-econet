# ─── Orthodox Econet — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection URL (used by Prisma Client at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/orthodox-econet?sslmode=require&pgbouncer=true&connect_timeout=15"

# Non-pooled connection URL (used by Prisma Migrate only)
DIRECT_URL="postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/orthodox-econet?sslmode=require"

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN="1234567890:ABCdefGhIjKlmNoPqRsTuVwXyZ"

# Full public URL of this app (used for webhook + Mini App links)
APP_URL="https://orthodox-econet.onrender.com"

# Telegram username of the support account (no @)
ADMIN_SUPPORT_USERNAME="OrthodoxEconetSupport"

# Telegram chat ID of the owner (for admin notifications on new registrations)
OWNER_CHAT_ID="123456789"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Strong random string — generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-long-random-string"

# JWT session duration
JWT_EXPIRES_IN="7d"

# ─── Cloudinary (file storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=10000

# ─── Donation Payment Info (seeded into Settings table on first boot) ─────────
# These are defaults — Owner can update them via Admin Settings UI without redeploy.
TELEBIRR_NUMBER="0941234567"
BANK_NAME="Commercial Bank of Ethiopia"
BANK_ACCOUNT_NAME="Orthodox Econet"
BANK_ACCOUNT_NUMBER="1000123456789"
BANK_BRANCH="Addis Ababa, Meskel Square"
